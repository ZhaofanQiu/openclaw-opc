# OpenClaw OPC v2.0 Environment Configuration

# Database
DATABASE_URL=
DB_TYPE=sqlite
OPC_DB_PATH=./data/opc.db

# OpenClaw Gateway
OPENCLAW_URL=http://localhost:8000
OPENCLAW_TOKEN=

# Server
HOST=0.0.0.0
PORT=8080
DEBUG=false

# Security
SECRET_KEY=your-secret-key-change-in-production
API_KEY_HEADER=X-API-Key

# Logging
LOG_LEVEL=INFO
