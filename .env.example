# OpenClaw OPC - Environment Configuration
# Copy this file to .env and modify values as needed

# ============================================
# Database Configuration
# ============================================
# SQLite (default, for single-user/single-node)
OPC_DB_PATH=./data/opc.db

# PostgreSQL (for multi-user/production)
# DATABASE_URL=postgresql://user:password@localhost/opc

# ============================================
# Server Configuration
# ============================================
# Host to bind (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
HOST=0.0.0.0

# Port for Core Service API
PORT=8080

# ============================================
# Security Configuration
# ============================================
# CORS allowed origins (comma-separated)
# For production, set specific domains:
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=*

# API Key for external integrations (optional)
# API_KEY=your-secret-api-key-here

# ============================================
# Budget Configuration
# ============================================
# Token to OC coin conversion rate (tokens per OC coin)
TOKEN_RATE=100

# Budget warning threshold (%)
BUDGET_WARNING_THRESHOLD=80

# Budget fuse threshold (%) - hard stop at this level
BUDGET_FUSE_THRESHOLD=100

# ============================================
# Task Configuration
# ============================================
# Default task timeout in minutes
TASK_TIMEOUT_MINUTES=30

# Max task timeout in minutes
MAX_TASK_TIMEOUT_MINUTES=480

# ============================================
# Partner Configuration
# ============================================
# Heartbeat interval in seconds
HEARTBEAT_INTERVAL=30

# Heartbeat timeout in seconds (mark offline after this)
HEARTBEAT_TIMEOUT=60

# Auto-assignment strategy: budget | workload | combined
AUTO_ASSIGN_STRATEGY=budget

# ============================================
# Notification Configuration
# ============================================
# Enable/disable notifications
ENABLE_NOTIFICATIONS=true

# Notification retention days
NOTIFICATION_RETENTION_DAYS=30

# ============================================
# Logging Configuration
# ============================================
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Log format: json | text
LOG_FORMAT=text

# ============================================
# Development Configuration
# ============================================
# Enable auto-reload (development only)
RELOAD=false

# Enable SQL query logging (development only)
SQL_ECHO=false

# ============================================
# OpenClaw Integration
# ============================================
# Path to OpenClaw config directory
# OPENCLAW_CONFIG_PATH=/root/.openclaw

# Default Partner Agent ID
DEFAULT_PARTNER_ID=main

# ============================================
# Production / External Access Configuration
# ============================================
# IMPORTANT: Enable API Key Authentication for secure external access
# See docs/CLOUDFLARE_TUNNEL.md for testing external access

# API Key Authentication - RECOMMENDED for external access
# When enabled, Dashboard and Reports require API Key login
API_KEY_AUTH_ENABLED=false

# API Key Secret - Used to sign API Keys (generate with: openssl rand -hex 32)
# IMPORTANT: Change this to a secure random string in production!
API_KEY_SECRET=change-me-to-a-secure-random-secret-key-32-chars

# ============================================
# Cloudflare Tunnel (Optional - Testing Only)
# ============================================
# ⚠️ 警告：以下配置尚未经验证，仅供测试使用
# 如需公网访问，建议使用传统方案（公网IP+DDNS）或云服务器

# Cloudflare Tunnel Token - For external access without public IP
# Get your token from: https://one.dash.cloudflare.com/ → Access → Tunnels
# Leave empty to disable tunnel (local access only)
# CLOUDFLARE_TUNNEL_TOKEN=

# Cloudflare Tunnel Edge IP Version (auto, 4, 6)
# TUNNEL_EDGE_IP_VERSION=auto

# Cloudflare Tunnel Region (optional, e.g., us, eu, apac)
# TUNNEL_REGION=

# ============================================
# Docker Compose Configuration
# ============================================
# Frontend port (only used in docker-compose.yml, not prod)
FRONTEND_PORT=3000
