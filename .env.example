# OpenClaw OPC Environment Configuration
# Copy this file to .env and modify values as needed

# ============================================
# Database Configuration
# ============================================

# Database type: sqlite (default) or postgresql
DB_TYPE=sqlite

# For SQLite (development)
OPC_DB_PATH=./data/opc.db

# For PostgreSQL (production)
# Uncomment and set these when using PostgreSQL:
# DB_TYPE=postgresql
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=opc
# PG_PASSWORD=your_secure_password_here
# PG_DATABASE=openclaw_opc

# Or use a full DATABASE_URL (overrides above settings)
# DATABASE_URL=postgresql://opc:password@localhost:5432/openclaw_opc

# ============================================
# Server Configuration
# ============================================

# API Server port
PORT=8080

# Frontend port
FRONTEND_PORT=3000

# CORS origins (comma-separated, or * for all)
CORS_ORIGINS=*

# ============================================
# Logging
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log format: json or text
LOG_FORMAT=text

# ============================================
# Budget Configuration
# ============================================

# Token to OC币 conversion rate (100 tokens = 1 OC币)
TOKEN_RATE=100

# Budget warning threshold percentage (default: 80%)
BUDGET_WARNING_THRESHOLD=80

# Budget fuse threshold percentage (default: 100%, hard limit)
BUDGET_FUSE_THRESHOLD=100

# ============================================
# Task Configuration
# ============================================

# Task timeout in minutes (default: 30)
TASK_TIMEOUT_MINUTES=30

# Auto-assign strategy: budget, skill, or random
AUTO_ASSIGN_STRATEGY=budget

# ============================================
# Partner Agent Configuration
# ============================================

# Partner Agent ID (default: main)
PARTNER_AGENT_ID=main

# Heartbeat interval in seconds (default: 30)
HEARTBEAT_INTERVAL=30

# Heartbeat timeout in seconds (default: 60)
HEARTBEAT_TIMEOUT=60

# ============================================
# Security
# ============================================

# Enable API Key authentication for dashboard access
API_KEY_AUTH_ENABLED=false

# ============================================
# Docker Compose Profiles
# ============================================

# Usage:
#   SQLite (default):     docker-compose up -d
#   With PostgreSQL:      docker-compose --profile postgres up -d
#   Full stack:           docker-compose --profile full up -d
