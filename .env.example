# OpenClaw OPC Environment Configuration
# Copy this file to .env and customize as needed

# ============================================
# Database Configuration
# ============================================

# Database type: sqlite | postgresql
DB_TYPE=sqlite

# SQLite Configuration (default for development)
OPC_DB_PATH=./data/opc.db

# PostgreSQL Configuration (for production)
# Uncomment and configure these to use PostgreSQL
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=opc
# PG_PASSWORD=your_secure_password
# PG_DATABASE=openclaw_opc

# Alternative: Use DATABASE_URL for full connection string
# DATABASE_URL=postgresql://opc:password@localhost:5432/openclaw_opc

# ============================================
# Server Configuration
# ============================================

# Backend port
PORT=8080

# Frontend port
FRONTEND_PORT=3000

# CORS origins (comma-separated)
CORS_ORIGINS=*

# ============================================
# Security Configuration
# ============================================

# Enable API key authentication
API_KEY_AUTH_ENABLED=false

# JWT Secret (generate a secure random string for production)
# JWT_SECRET=your-secret-key-here

# ============================================
# Budget Configuration
# ============================================

# Token to OC币 conversion rate (default: 100 tokens = 1 OC币)
TOKEN_RATE=100

# Budget warning threshold (percentage)
BUDGET_WARNING_THRESHOLD=80

# Budget fuse threshold (percentage, 100 = exact limit)
BUDGET_FUSE_THRESHOLD=100

# ============================================
# Task Configuration
# ============================================

# Task timeout in minutes
TASK_TIMEOUT_MINUTES=30

# Auto-assign strategy: budget | skill | round_robin
AUTO_ASSIGN_STRATEGY=budget

# ============================================
# Partner Agent Configuration
# ============================================

# Partner Agent ID (the main Agent that manages the company)
PARTNER_AGENT_ID=main

# ============================================
# Heartbeat Configuration
# ============================================

# Heartbeat interval in seconds
HEARTBEAT_INTERVAL=30

# Heartbeat timeout in seconds
HEARTBEAT_TIMEOUT=60

# ============================================
# Logging Configuration
# ============================================

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Log format: json | text
LOG_FORMAT=text

# ============================================
# OpenClaw Integration
# ============================================

# OpenClaw Gateway URL (for sessions_send integration)
# OPENCLAW_GATEWAY_URL=http://localhost:8080

# ============================================
# Docker Configuration
# ============================================

# PostgreSQL ports (when using Docker)
PG_PORT=5432

# ============================================
# Migration Notes
# ============================================
# 
# To migrate from SQLite to PostgreSQL:
# 
# 1. Start PostgreSQL with Docker:
#    docker-compose --profile postgres up -d postgres
#
# 2. Run migration script:
#    ./scripts/setup_postgres.sh migrate
#
# 3. Switch to PostgreSQL:
#    ./scripts/setup_postgres.sh switch-postgres
#
# 4. Restart application:
#    docker-compose up -d
#
# Or use the helper script:
#    ./scripts/setup_postgres.sh init
#    ./scripts/setup_postgres.sh migrate
#
